---
import '../styles/global.css';
import { SITE_URL, SEMINARIO, FACEBOOK_PIXEL_ID } from '../config/seminario';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const {
  title = SEMINARIO.nome + ' | Doutora Escola',
  description = 'Participe do ' + SEMINARIO.nome + ' e descubra o que escrever e como escrever relatórios técnicos com a Dra. Guaciara Fornaciari. Aula 100% online e gratuita com certificado de participação.',
  canonicalPath = '/',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-56HN95B');</script>
    <!-- End Google Tag Manager -->

    <!-- Meta Pixel (Facebook) - snippet oficial no head -->
    <script is:inline define:vars={{ FACEBOOK_PIXEL_ID }}>
      !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', FACEBOOK_PIXEL_ID);
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none" alt="" src={"https://www.facebook.com/tr?id=" + FACEBOOK_PIXEL_ID + "&ev=PageView&noscript=1"} /></noscript>
    <link rel="preconnect" href="https://connect.facebook.net" crossorigin />
    <link rel="dns-prefetch" href="https://www.facebook.com" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="canonical" href={SITE_URL + canonicalPath} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="seminário de relatórios, relatórios pedagógicos, BNCC, educação infantil, Doutora Escola, Guaciara Fornaciari" />
    <meta name="theme-color" content="#e8590c" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL + canonicalPath} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Doutora Escola - Seminário de Relatórios" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:image" content="https://seminario-relatorio.pages.dev/images/seminario/og2.png" />
    <meta property="og:image:secure_url" content="https://seminario-relatorio.pages.dev/images/seminario/og2.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="1200" />
    <meta property="og:image:alt" content={SEMINARIO.nome + ' — Doutora Escola'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://seminario-relatorio.pages.dev/images/seminario/og2.png" />
    <meta name="twitter:image:alt" content={SEMINARIO.nome + ' — Doutora Escola'} />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0&family=Poppins:wght@400;500;600;700;800&display=swap"
    />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-56HN95B"
      height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <slot />

    {/* Cookies — popup discreto */}
    <div
      id="cookie-banner"
      role="dialog"
      aria-label="Uso de cookies"
      class="fixed z-50 max-w-md w-[calc(100%-2rem)] md:w-full left-4 right-4 md:left-auto md:right-6 bottom-4 md:bottom-6 mx-auto md:mx-0 rounded-2xl border border-gray-200/80 bg-white/95 text-gray-600 text-xs leading-relaxed shadow-lg backdrop-blur-sm px-4 py-3.5 md:px-5 md:py-4"
      style="display: none;"
    >
      <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4">
        <p class="flex-1 text-left">
          Usamos cookies para personalizar conteúdos e melhorar a sua experiência.
          <a href="https://doutoraescola.com.br/privacidade/privacidade.html" target="_blank" rel="noopener noreferrer" class="text-[#e8590c] underline underline-offset-2 hover:text-[#c44a08] whitespace-nowrap">Saiba mais</a>
        </p>
        <button
          type="button"
          id="cookie-accept"
          class="shrink-0 self-end sm:self-center bg-gray-900 hover:bg-gray-800 text-white text-xs font-semibold uppercase tracking-wide px-4 py-2 rounded-lg transition-colors"
        >
          Ok
        </button>
      </div>
    </div>

    <script is:inline data-cfasync="false">
      (function () {
        var ALLOWED = ['aff', 'utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term', 'src', 'ref'];
        var HOST_MATCH = /(^|\.)((fm\.doutoraescola\.com\.br)|(pay\.kiwify\.com(\.br)?)|(voomp\.com\.br))$/;

        function appendLandingParamsToUrl(targetUrl) {
          if (!targetUrl) return targetUrl;
          var landingParams;
          var out;
          try {
            landingParams = new URL(window.location.href).searchParams;
            out = new URL(targetUrl, window.location.origin);
          } catch (e) {
            return targetUrl;
          }
          landingParams.forEach(function (value, key) {
            if (ALLOWED.indexOf(key) === -1) return;
            if (!out.searchParams.has(key)) out.searchParams.set(key, value);
          });
          return out.href;
        }

        document.addEventListener(
          'click',
          function (event) {
            var target = event.target;
            if (!(target instanceof Element)) return;
            var link = target.closest('a[href]');
            if (!link) return;

            var href = link.getAttribute('href');
            if (!href || href === '#' || href.indexOf('javascript:') === 0) return;

            var parsed;
            try {
              parsed = new URL(href, window.location.origin);
            } catch (e) {
              return;
            }
            if (!HOST_MATCH.test(parsed.hostname)) return;

            link.setAttribute('href', appendLandingParamsToUrl(parsed.href));
          },
          true
        );

        /* Cookie banner discreto */
        (function () {
          var banner = document.getElementById('cookie-banner');
          var acceptBtn = document.getElementById('cookie-accept');
          if (!banner || !acceptBtn) return;
          try {
            if (!localStorage.getItem('cookies_accepted')) {
              banner.style.display = 'block';
            }
          } catch (e) {}
          acceptBtn.addEventListener('click', function () {
            try {
              localStorage.setItem('cookies_accepted', '1');
            } catch (e) {}
            banner.style.display = 'none';
          });
        })();
      })();
    </script>
  </body>
</html>
