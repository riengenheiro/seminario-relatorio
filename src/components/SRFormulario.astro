---
---
<section id="formulario" class="py-16 md:py-24 px-6 bg-gradient-to-b from-white to-[#F5F5F5] scroll-mt-4">
  <div class="max-w-xl mx-auto">
    <div class="text-center mb-8">
      <span class="inline-block mb-3 px-4 py-1 rounded-full bg-[#4CAF50]/10 text-[#2E7D32] text-xs md:text-sm font-bold uppercase tracking-wider">
        Garanta sua vaga
      </span>
      <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-2">Preencha seus dados para confirmar</h2>
      <p class="text-gray-600">
        Você receberá o link da aula e os avisos importantes por e-mail e WhatsApp.
      </p>
      <p id="tier-escolhido" class="mt-4 text-sm font-bold text-[#e8590c]"></p>
    </div>

    <form id="form-seminario" action="/obrigado/" method="get" class="bg-white rounded-3xl shadow-xl border border-gray-200 p-6 md:p-8">
      <input type="hidden" name="tier" id="input-tier" value="gratuito" />

      <div class="mb-5">
        <label for="nome" class="block text-sm font-bold text-gray-800 mb-2">Seu nome completo</label>
        <input
          id="nome"
          name="nome"
          type="text"
          required
          autocomplete="name"
          placeholder="Digite seu nome"
          class="w-full rounded-xl border-2 border-gray-200 px-4 py-3 text-base focus:outline-none focus:border-[#e8590c] focus:ring-2 focus:ring-[#e8590c]/20 transition"
        />
      </div>

      <div class="mb-5">
        <label for="email" class="block text-sm font-bold text-gray-800 mb-2">Seu melhor e-mail</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="voce@exemplo.com"
          class="w-full rounded-xl border-2 border-gray-200 px-4 py-3 text-base focus:outline-none focus:border-[#e8590c] focus:ring-2 focus:ring-[#e8590c]/20 transition"
        />
      </div>

      <div class="mb-6">
        <label for="whatsapp" class="block text-sm font-bold text-gray-800 mb-2">WhatsApp (com DDD)</label>
        <input
          id="whatsapp"
          name="whatsapp"
          type="tel"
          required
          autocomplete="tel"
          inputmode="numeric"
          placeholder="(11) 91234-5678"
          class="w-full rounded-xl border-2 border-gray-200 px-4 py-3 text-base focus:outline-none focus:border-[#e8590c] focus:ring-2 focus:ring-[#e8590c]/20 transition"
        />
      </div>

      <button
        type="submit"
        class="block w-full text-center text-white font-black text-lg py-5 rounded-xl transition-all duration-150 active:scale-[0.98]"
        style="background:#2E7D32; box-shadow: 0 5px 0 #1a4d1e;"
      >
        GARANTIR MINHA VAGA
      </button>

      <p class="text-center text-xs text-gray-500 mt-4 leading-relaxed">
        Ao clicar, você aceita nossos
        <a href="https://doutoraescola.com.br/privacidade/termo.html" target="_blank" rel="noopener noreferrer" class="underline hover:text-[#e8590c]">Termos de Uso</a>
        e
        <a href="https://doutoraescola.com.br/privacidade/privacidade.html" target="_blank" rel="noopener noreferrer" class="underline hover:text-[#e8590c]">Política de Privacidade</a>.
      </p>
    </form>
  </div>
</section>

<script is:inline>
  (function () {
    var TIER_LABELS = {
      gratuito: 'Plano escolhido: GRATUITO',
      vip: 'Plano escolhido: VIP — R$ 19,70',
      platinum: 'Plano escolhido: PLATINUM — R$ 49,70',
    };

    function applyTier(tier) {
      if (!tier) tier = 'gratuito';
      var input = document.getElementById('input-tier');
      var label = document.getElementById('tier-escolhido');
      if (input) input.value = tier;
      if (label) label.textContent = TIER_LABELS[tier] || TIER_LABELS.gratuito;
    }

    document.addEventListener('click', function (e) {
      var target = e.target;
      if (!(target instanceof Element)) return;
      var btn = target.closest('.js-tier-cta');
      if (!btn) return;
      var tier = btn.getAttribute('data-tier');
      applyTier(tier);
    });

    applyTier('gratuito');

    var phone = document.getElementById('whatsapp');
    if (phone) {
      phone.addEventListener('input', function () {
        var v = phone.value.replace(/\D/g, '').slice(0, 11);
        if (v.length > 10) {
          phone.value = '(' + v.slice(0, 2) + ') ' + v.slice(2, 7) + '-' + v.slice(7);
        } else if (v.length > 6) {
          phone.value = '(' + v.slice(0, 2) + ') ' + v.slice(2, 6) + '-' + v.slice(6);
        } else if (v.length > 2) {
          phone.value = '(' + v.slice(0, 2) + ') ' + v.slice(2);
        } else {
          phone.value = v;
        }
      });
    }

    var form = document.getElementById('form-seminario');
    if (form) {
      form.addEventListener('submit', function () {
        try {
          var nome = (document.getElementById('nome') || {}).value || '';
          sessionStorage.setItem('sr_nome', nome.trim());
        } catch (e) {}
        if (window.fbq) {
          try { window.fbq('track', 'Lead'); } catch (e) {}
        }
      });
    }
  })();
</script>
