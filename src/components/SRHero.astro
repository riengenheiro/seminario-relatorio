---
import { SEMINARIO } from '../config/seminario';
---
<section class="bg-gradient-to-b from-[#2C3E99] to-[#1a2570] text-white pt-6 pb-4 px-4 md:pt-12 md:pb-16 md:px-6">
  <div class="max-w-4xl mx-auto text-center">
    <!-- Tag minimal -->
    <span class="inline-block mb-3 px-3 py-1 rounded-full bg-white/15 border border-white/25 text-[10px] md:text-xs font-bold uppercase tracking-wider">
      Seminário online • 100% gratuito
    </span>

    <!-- Headline compacta -->
    <h1 class="text-xl md:text-4xl font-extrabold mb-3 leading-tight">
      <span class="text-[#FFD54F]">Seminário de Relatórios</span>
    </h1>
    <p class="text-sm md:text-lg text-white/90 mb-3 max-w-xl mx-auto">
      Descubra <strong>o que escrever</strong> e <strong>como escrever</strong> relatórios técnicos alinhados à BNCC
    </p>

    <!-- Data/hora inline -->
    <div class="flex items-center justify-center gap-2 md:gap-4 mb-3 text-xs md:text-sm">
      <span class="bg-white/10 px-3 py-1.5 rounded-lg">📅 {SEMINARIO.dataExibida}</span>
      <span class="bg-white/10 px-3 py-1.5 rounded-lg">🕐 {SEMINARIO.horaExibida}</span>
    </div>

    <!-- Certificado badge -->
    <div class="inline-flex items-center gap-1 bg-[#4CAF50]/20 border border-[#4CAF50] rounded-full px-3 py-1 text-[10px] md:text-xs font-bold mb-4">
      <span class="text-[#FFD54F]">+</span>
      Certificado {SEMINARIO.cargaGratuita} — GRATUITO
    </div>
  </div>
</section>
