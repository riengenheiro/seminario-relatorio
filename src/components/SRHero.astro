---
---
<section class="bg-[#111827] border-b border-white/10 py-8 md:py-16 px-5 text-white">
  <div class="max-w-5xl mx-auto">

    <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">

      {/* ── COLUNA ESQUERDA: texto — wordmark, H1 e CTA centralizados ── */}
      <div class="flex flex-col items-center text-center w-full max-w-2xl mx-auto">

        {/* Selo superior (super-headline) */}
        <p class="mb-5 inline-flex items-center rounded-full border border-white/30 px-4 py-1.5 text-[11px] sm:text-xs font-semibold uppercase tracking-[0.15em] text-white/90">
          Seminário Online e Gratuito • Certificado de 10h
        </p>

        {/* Wordmark (logo textual) — DM Serif Display: contraste com Poppins do restante */}
        <div class="mb-6 inline-flex flex-col items-center leading-[1.05] font-['DM_Serif_Display',Georgia,serif]">
          <span class="text-xl sm:text-2xl md:text-3xl font-normal uppercase tracking-[0.18em] text-white/90">
            Seminário de
          </span>
          <span class="text-[2.35rem] sm:text-[2.75rem] md:text-[3.75rem] font-normal uppercase tracking-[0.06em] text-white -mt-0.5">
            Relatórios
          </span>
          <span class="mt-3 h-1 w-28 rounded-full" style="background-color: #e8590c;"></span>
        </div>

        {/* H1 — Headline principal com destaques em laranja */}
        <h1 class="text-2xl md:text-[2.1rem] font-bold text-white mb-4 leading-snug tracking-tight">
          O{' '}
          <span class="uppercase tracking-tight" style="color: #e8590c;">passo a passo definitivo</span>
          {' '}para escrever relatórios precisos,{' '}
          <span class="uppercase tracking-tight" style="color: #e8590c;">sem travar na frente da página em branco</span>.
        </h1>

        {/* Sub-headline */}
        <p class="text-sm md:text-base text-white/80 mb-4 font-medium">
          Descubra a técnica exata para saber <strong class="text-white">o que colocar no papel</strong> e <strong class="text-white">como escrever</strong> — ganhando tempo e segurança na hora das entregas.
        </p>

        {/* Info / Data — destaque grande */}
        <p class="text-base md:text-lg font-bold text-white mb-6 leading-snug">
          Seminário ao vivo com a{' '}
          <span style="color: #e8590c;">Dra. Guaciara Fornaciari</span>
          {' '}· 26 de maio às 19h37
        </p>

        {/* CTA principal — leva aos planos (#tiers) */}
        <div class="mb-5 w-full flex flex-col items-center">
          <a
            href="#tiers"
            class="inline-block w-full max-w-md text-center text-white font-bold text-lg md:text-xl uppercase tracking-wide px-8 py-4 rounded-xl transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0"
            style="background-color: rgb(253, 149, 26);"
            onmouseover="this.style.backgroundColor='rgb(235, 130, 18)'"
            onmouseout="this.style.backgroundColor='rgb(253, 149, 26)'"
          >
            Garantir minha vaga gratuita agora →
          </a>
          <p class="mt-2 text-xs text-white/55 flex items-center justify-center gap-2 w-full">
            <span class="inline-block w-2 h-2 rounded-full bg-red-500 flex-shrink-0" style="animation: pulse 1.5s infinite;"></span>
            100% gratuito · vagas limitadas
          </p>
          <p class="mt-3 text-sm text-white/80 font-medium">
            Mais de <strong class="text-white">4.700 professoras</strong> já participaram
          </p>

          {/* Avatar + nome (só mobile) */}
          <div class="flex items-center justify-center gap-3 mt-4 md:hidden w-full">
            <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-white/25 flex-shrink-0 bg-white/10">
              <img
                src="/images/seminario/guaciara-foto.webp"
                alt="Guaciara Fornaciari"
                class="w-full h-full object-cover"
                width="48"
                height="48"
              />
            </div>
            <p class="text-sm text-white/80 font-medium leading-tight">
              com <strong class="text-white">Dra. Guaciara Fornaciari</strong>
            </p>
          </div>
        </div>

      </div>

      {/* ── COLUNA DIREITA: foto — só no desktop ── */}
      <div class="hidden md:flex flex-col items-center gap-4">

        <div class="w-72 h-[340px] rounded-2xl overflow-hidden border-4 border-white/20 shadow-2xl bg-white/5">
          <img
            src="/images/seminario/guaciara-foto.webp"
            alt="Guaciara Fornaciari"
            class="w-full h-full object-cover"
            width="512"
            height="512"
          />
        </div>

        <div class="rounded-2xl px-5 py-4 text-center w-full max-w-[288px] text-white border border-white/15 bg-white/5">
          <p class="font-bold text-base mb-1">Dra. Guaciara Fornaciari</p>
          <p class="text-xs text-white/70">Fonoaudióloga · Professora · Fundadora Doutora Escola</p>
        </div>

      </div>

    </div>
  </div>
</section>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
