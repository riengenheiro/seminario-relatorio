---
import { SEMINARIO } from '../config/seminario';
---
<section class="bg-white border-b border-gray-100 py-8 md:py-16 px-5">
  <div class="max-w-5xl mx-auto">

    <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">

      {/* ── COLUNA ESQUERDA: texto — aparece primeiro em qualquer tela ── */}
      <div class="flex flex-col">

        {/* Avatar + nome (só mobile) */}
        <div class="flex items-center gap-3 mb-4 md:hidden">
          <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-gray-200 flex-shrink-0 bg-gray-100">
            <img
              src="/images/seminario/guaciara-foto.webp"
              alt="Guaciara Fornaciari"
              class="w-full h-full object-cover"
              width="48"
              height="48"
            />
          </div>
          <p class="text-sm text-gray-600 font-medium leading-tight">
            com <strong class="text-gray-900">Guaciara Fornaciari</strong>
          </p>
        </div>

        {/* Eyebrow */}
        <span class="inline-flex self-start items-center mb-4 px-4 py-1.5 rounded-full border border-blue-200 bg-blue-50 text-[#2C3E99] text-[11px] font-semibold uppercase tracking-[0.2em]">
          Seminário online · gratuito
        </span>

        {/* H1 */}
        <h1 class="text-2xl md:text-[2.1rem] font-bold text-gray-900 mb-4 leading-snug tracking-tight">
          Participe do Seminário de Relatórios e{' '}
          <span class="uppercase tracking-tight" style="color: #e8590c;">descubra exatamente o que colocar no papel — com a técnica certa</span>
          {' '}— nesse momento que vivemos.
        </h1>

        {/* Sub + data + reforço */}
        <p class="text-sm md:text-base text-gray-600 mb-2 font-medium">
          Aula online e gratuita + Certificado de {SEMINARIO.cargaGratuita}
        </p>
        <p class="text-sm md:text-base font-semibold text-gray-900 mb-1">
          {SEMINARIO.dataExibida} às {SEMINARIO.horaExibida}
        </p>
        <p class="text-sm md:text-base text-gray-600 mb-6">
          As aulas são 100% online e gratuitas
        </p>

        {/* CTA principal — leva aos planos (#tiers) */}
        <div class="mb-5">
          <a
            href="#tiers"
            class="inline-block w-full md:w-auto text-center text-white font-bold text-lg md:text-xl uppercase tracking-wide px-8 py-4 rounded-xl transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0"
            style="background-color: #e8590c;"
            onmouseover="this.style.backgroundColor='#c44a08'"
            onmouseout="this.style.backgroundColor='#e8590c'"
          >
            Garantir minha vaga gratuita →
          </a>
          <p class="mt-2 text-xs text-gray-400 flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-red-500 flex-shrink-0" style="animation: pulse 1.5s infinite;"></span>
            100% gratuito · vagas limitadas
          </p>
        </div>

      </div>

      {/* ── COLUNA DIREITA: foto — só no desktop ── */}
      <div class="hidden md:flex flex-col items-center gap-4">

        <div class="w-72 h-[340px] rounded-2xl overflow-hidden border-4 border-white shadow-2xl bg-gray-100">
          <img
            src="/images/seminario/guaciara-foto.webp"
            alt="Guaciara Fornaciari"
            class="w-full h-full object-cover"
            width="512"
            height="512"
          />
        </div>

        <div class="rounded-2xl px-5 py-4 text-center w-full max-w-[288px] text-white" style="background-color: #1a2570;">
          <p class="font-bold text-base mb-1">Guaciara Fornaciari</p>
          <p class="text-xs" style="color: rgba(255,255,255,0.7);">Fonoaudióloga · Professora · Fundadora Doutora Escola</p>
        </div>

      </div>

    </div>
  </div>
</section>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
