---
import { SEMINARIO, CHECKOUT_GRATUITO } from '../config/seminario';
---
<section class="bg-white border-b border-gray-100 py-8 md:py-16 px-5">
  <div class="max-w-5xl mx-auto">

    <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">

      {/* ── COLUNA ESQUERDA: texto — aparece primeiro em qualquer tela ── */}
      <div class="flex flex-col">

        {/* Avatar + nome (só mobile) */}
        <div class="flex items-center gap-3 mb-4 md:hidden">
          <div class="w-12 h-12 rounded-full overflow-hidden border-2 border-gray-200 flex-shrink-0 bg-gray-100">
            <img
              src="/images/seminario/guaciara-foto.webp"
              alt="Guaciara Fornaciari"
              class="w-full h-full object-cover"
              width="48"
              height="48"
            />
          </div>
          <p class="text-sm text-gray-600 font-medium leading-tight">
            com <strong class="text-gray-900">Guaciara Fornaciari</strong>
          </p>
        </div>

        {/* Eyebrow */}
        <span class="inline-flex self-start items-center mb-4 px-4 py-1.5 rounded-full border border-blue-200 bg-blue-50 text-[#2C3E99] text-[11px] font-semibold uppercase tracking-[0.2em]">
          Seminário online · gratuito
        </span>

        {/* H1 */}
        <h1 class="text-2xl md:text-[2.1rem] font-bold text-gray-900 mb-4 leading-snug tracking-tight">
          Participe do Seminário de Relatórios e descubra exatamente o que colocar no papel — com a técnica certa — nesse momento que vivemos.
        </h1>

        {/* Sub */}
        <p class="text-sm md:text-base text-gray-600 mb-6 font-medium">
          Aula online e gratuita + Certificado de {SEMINARIO.cargaGratuita}
        </p>

        {/* CTA principal — direto ao checkout */}
        <div class="mb-5">
          <a
            href={CHECKOUT_GRATUITO}
            class="inline-block w-full md:w-auto text-center text-white font-bold text-base px-8 py-4 rounded-xl transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0"
            style="background-color: #e8590c;"
            onmouseover="this.style.backgroundColor='#c44a08'"
            onmouseout="this.style.backgroundColor='#e8590c'"
          >
            Garantir minha vaga gratuita →
          </a>
          <p class="mt-2 text-xs text-gray-400 flex items-center gap-2">
            <span class="inline-block w-2 h-2 rounded-full bg-red-500 flex-shrink-0" style="animation: pulse 1.5s infinite;"></span>
            100% gratuito · vagas limitadas
          </p>
        </div>

        {/* Link secundário para planos pagos */}
        <a href="#tiers" class="text-sm font-medium mb-6 self-start" style="color: #2C3E99;">
          Ver planos VIP e Platinum ↓
        </a>

        {/* Data e hora — linha compacta */}
        <p class="text-sm text-gray-500 mb-7">
          📅 <strong class="text-gray-700">{SEMINARIO.dataExibida}</strong>
          &nbsp;·&nbsp;
          🕐 <strong class="text-gray-700">{SEMINARIO.horaExibida}</strong>
        </p>

        {/* Pilares — abaixo do CTA */}
        <div class="flex flex-col gap-3">
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-orange-50 border border-orange-100 flex items-center justify-center flex-shrink-0 text-sm">❤️</div>
            <span class="text-sm text-gray-600 pt-1 leading-snug">Como um relatório pode salvar a vida de uma criança — a história real</span>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-orange-50 border border-orange-100 flex items-center justify-center flex-shrink-0 text-sm">🏆</div>
            <span class="text-sm text-gray-600 pt-1 leading-snug">Como o relatório constrói sua autoridade e te faz ser procurada</span>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-8 h-8 rounded-full bg-orange-50 border border-orange-100 flex items-center justify-center flex-shrink-0 text-sm">✨</div>
            <span class="text-sm text-gray-600 pt-1 leading-snug">É a hora de mostrar tudo que você construiu na sua carreira</span>
          </div>
        </div>

      </div>

      {/* ── COLUNA DIREITA: foto — só no desktop ── */}
      <div class="hidden md:flex flex-col items-center gap-4">

        <div class="w-72 h-[340px] rounded-2xl overflow-hidden border-4 border-white shadow-2xl bg-gray-100">
          <img
            src="/images/seminario/guaciara-foto.webp"
            alt="Guaciara Fornaciari"
            class="w-full h-full object-cover"
            width="512"
            height="512"
          />
        </div>

        <div class="rounded-2xl px-5 py-4 text-center w-full max-w-[288px] text-white" style="background-color: #1a2570;">
          <p class="font-bold text-base mb-1">Guaciara Fornaciari</p>
          <p class="text-xs" style="color: rgba(255,255,255,0.7);">Fonoaudióloga · Professora · Fundadora Doutora Escola</p>
        </div>

      </div>

    </div>
  </div>
</section>

<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
</style>
