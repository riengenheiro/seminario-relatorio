---
---
<section class="bg-white border-t border-gray-100 py-10 px-5">
  <div class="max-w-5xl mx-auto">

    <div class="flex flex-col md:flex-row items-center md:items-start gap-5 md:gap-8">

      {/* Foto */}
      <div class="w-16 h-16 md:w-20 md:h-20 rounded-full overflow-hidden border-2 border-gray-200 flex-shrink-0 bg-gray-100">
        <img
          src="/images/seminario/guaciara-foto.webp"
          alt="Guaciara Fornaciari"
          class="w-full h-full object-cover"
          width="80"
          height="80"
        />
      </div>

      {/* Texto */}
      <div class="text-center md:text-left flex-1">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] mb-1" style="color: #e8590c;">Quem conduz o Seminário</p>
        <h2 class="text-lg md:text-xl font-bold text-gray-900 mb-1">Guaciara Fornaciari</h2>
        <p class="text-sm text-gray-500 mb-3">Fonoaudióloga · Professora · Ex-coordenadora pedagógica</p>
        <p class="text-sm text-gray-700 leading-relaxed">
          Criadora da Fábrica Mágica, plataforma com mais de <strong>4.747 professoras</strong> em todo o Brasil.
          Mais de <strong>19 anos</strong> de experiência na Educação Infantil e mais de <strong>500 aulas</strong> realizadas.
        </p>
      </div>

      {/* Números — só desktop */}
      <div class="hidden md:flex gap-4 flex-shrink-0">
        <div class="text-center px-4 py-3 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xl font-bold" style="color: #e8590c;">4.747</p>
          <p class="text-[11px] text-gray-500 leading-tight">professoras</p>
        </div>
        <div class="text-center px-4 py-3 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xl font-bold" style="color: #e8590c;">19 anos</p>
          <p class="text-[11px] text-gray-500 leading-tight">experiência</p>
        </div>
        <div class="text-center px-4 py-3 bg-gray-50 rounded-xl border border-gray-100">
          <p class="text-xl font-bold" style="color: #e8590c;">+500</p>
          <p class="text-[11px] text-gray-500 leading-tight">aulas</p>
        </div>
      </div>

    </div>

  </div>
</section>
