---
import { SEMINARIO, CHECKOUT_GRATUITO, CHECKOUT_VIP, CHECKOUT_PLATINUM } from '../config/seminario';
---
<section id="tiers" class="bg-gray-50 py-12 md:py-20 px-5">
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-8 md:mb-12">
      <p class="text-[11px] md:text-xs font-medium text-gray-500 uppercase tracking-[0.2em] mb-2">
        Escolha sua participação
      </p>
      <h2 class="text-xl md:text-3xl font-bold text-gray-900">Garanta sua vaga</h2>
    </div>

    <div class="space-y-3 md:space-y-0 md:grid md:grid-cols-3 md:gap-5">

      {/* GRATUITO */}
      <div class="bg-white rounded-lg border border-gray-200 p-5 md:p-6 flex flex-col">
        <div class="mb-4 pb-4 border-b border-gray-100">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Gratuito</p>
          <p class="text-3xl font-bold text-gray-900">R$ 0</p>
        </div>
        <ul class="space-y-2.5 text-sm text-gray-700 mb-5 flex-1">
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Acesso completo ao Seminário ao vivo</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Certificado de participação digital ({SEMINARIO.cargaGratuita})</span>
          </li>
        </ul>
        <a href={CHECKOUT_GRATUITO} class="block w-full text-center text-gray-900 font-semibold text-sm py-3 rounded-md border border-gray-900 hover:bg-gray-900 hover:text-white transition-colors">
          Inscrição gratuita
        </a>
      </div>

      {/* VIP */}
      <div class="bg-white rounded-lg border border-gray-200 p-5 md:p-6 flex flex-col">
        <div class="mb-4 pb-4 border-b border-gray-100">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">VIP</p>
          <p class="text-3xl font-bold text-gray-900">R$ 19,70</p>
        </div>
        <ul class="space-y-2.5 text-sm text-gray-700 mb-5 flex-1">
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Tudo do Plano Gratuito</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Certificado Assinado no GOV.BR em PDF ({SEMINARIO.cargaVip})</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Encontro exclusivo com a Gua, 30 minutos antes da aula</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Acesso vitalício à gravação</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Material completo da aula em PDF</span>
          </li>
        </ul>
        <a href={CHECKOUT_VIP} class="block w-full text-center text-white font-semibold text-sm py-3 rounded-md bg-gray-900 hover:bg-black transition-colors">
          Quero ser VIP
        </a>
      </div>

      {/* PLATINUM */}
      <div class="bg-white rounded-lg border-2 border-gray-900 p-5 md:p-6 flex flex-col relative">
        <span class="absolute -top-2.5 left-5 bg-gray-900 text-white text-[10px] font-semibold px-2.5 py-0.5 rounded uppercase tracking-wider">
          Recomendado
        </span>
        <div class="mb-4 pb-4 border-b border-gray-100">
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wider mb-1">Platinum</p>
          <p class="text-3xl font-bold text-gray-900">R$ 39,70</p>
        </div>
        <ul class="space-y-2.5 text-sm text-gray-700 mb-5 flex-1">
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Todos os benefícios do Plano VIP</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Certificado Assinado no GOV.BR em PDF ({SEMINARIO.cargaPlatinum})</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Certificado físico impresso enviado pelos Correios</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>15 Modelos Prontos de Relatórios</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Grupo Aberto no WhatsApp para dúvidas e networking</span>
          </li>
          <li class="flex items-start gap-2.5">
            <span class="text-gray-400 mt-0.5">—</span>
            <span>Bônus: Aula extra gravada + Ebook</span>
          </li>
        </ul>
        <a href={CHECKOUT_PLATINUM} class="block w-full text-center text-white font-semibold text-sm py-3 rounded-md bg-gray-900 hover:bg-black transition-colors">
          Quero o Platinum
        </a>
      </div>
    </div>
  </div>
</section>
