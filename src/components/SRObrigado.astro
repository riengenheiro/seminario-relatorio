---
import SRFooter from './SRFooter.astro';
import { SEMINARIO } from '../config/seminario';

interface Props {
  tier: 'Gold' | 'VIP' | 'Platinum';
  whatsappUrl: string;
  variant?: 'standard' | 'platinum';
}

const { tier, whatsappUrl, variant = 'standard' } = Astro.props;

const isPlatinum = variant === 'platinum';
const isVIP = tier === 'VIP';
const isGold = tier === 'Gold';

// Cores consistentes com a landing page
const tierColor = isPlatinum ? '#ff7300' : isVIP ? '#16a34a' : '#e8590c';
const tierClass = isPlatinum ? 'text-[#ff7300]' : isVIP ? 'text-[#16a34a]' : 'text-[#FFD54F]';
const badgeClass = isPlatinum 
  ? 'bg-[#ff7300] text-white' 
  : isVIP 
    ? 'bg-[#16a34a] text-white' 
    : 'bg-[#e8590c] text-white';
const heroClass = 'bg-[#111827] text-white';
const buttonClass = isPlatinum 
  ? 'bg-[#ff7300] hover:bg-[#e86800]' 
  : isVIP 
    ? 'bg-[#16a34a] hover:bg-[#15803d]' 
    : 'bg-[#fd7200] hover:bg-[#e56500]';
const buttonShadow = 'shadow-[0_8px_30px_rgba(232,89,12,0.4)] hover:shadow-[0_12px_40px_rgba(232,89,12,0.55)]';
const groupName = isPlatinum ? 'grupo aberto Platinum' : 'grupo oficial de WhatsApp';
const redirectLabel = isPlatinum ? 'grupo aberto' : 'grupo';

// Título e mensagem específicos por tier
const tierTitle = isPlatinum 
  ? 'Platinum' 
  : isVIP 
    ? 'VIP' 
    : 'Gold';

const tierMessage = isPlatinum 
  ? 'Você está no plano mais completo. Entre agora no grupo aberto Platinum para receber o link da aula, avisos prioritários e orientações do seu acesso.'
  : isVIP
    ? 'Você escolheu a experiência completa VIP. Entre agora no grupo oficial para receber o link da aula e todos os avisos importantes.'
    : 'Sua vaga gratuita está confirmada. Entre agora no grupo oficial para receber o link da aula e todos os avisos importantes.';
---
<main class="min-h-screen w-full bg-white text-black font-sans antialiased flex flex-col">

  {/* Header com identidade visual consistente com a landing */}
  <section class={`${heroClass} border-b border-white/10`}>
    <div class="max-w-5xl mx-auto px-5 py-8 md:py-12">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
        
        {/* Coluna esquerda: Wordmark e confirmação */}
        <div class="text-center md:text-left">
          {/* Wordmark - mesmo estilo da landing */}
          <div class="mb-6 inline-flex flex-col items-center md:items-start leading-[1.05] font-['DM_Serif_Display',Georgia,serif]">
            <span class="text-xl sm:text-2xl md:text-3xl font-normal uppercase tracking-[0.18em] text-white/90">
              Seminário de
            </span>
            <span class="text-[2.35rem] sm:text-[2.75rem] md:text-[3.5rem] font-normal uppercase tracking-[0.06em] text-white -mt-0.5">
              Relatórios
            </span>
            <span class="mt-3 h-1 w-28 rounded-full" style={`background-color: ${tierColor};`}></span>
          </div>

          {/* Badge de confirmação */}
          <span class={`inline-block mb-4 px-4 py-1.5 rounded-full text-xs md:text-sm font-bold uppercase tracking-wider shadow-lg ${badgeClass}`}>
            ✓ Inscrição {tierTitle} confirmada
          </span>

          <h1 class="text-2xl md:text-3xl font-bold mb-4 leading-tight text-white">
            Parabéns<span id="nome-aluna"></span>!<br />
            Sua vaga <span class={tierClass}>{tier}</span> está confirmada.
          </h1>

          <p class="text-base text-white/80 leading-relaxed">
            {tierMessage}
          </p>
        </div>

        {/* Coluna direita: Foto da Guaciara (consistente com landing) */}
        <div class="flex flex-col items-center gap-4">
          <div class="w-64 h-72 md:w-72 md:h-[340px] rounded-2xl overflow-hidden border-4 border-white/20 shadow-2xl bg-white/5">
            <img
              src="/images/seminario/guaciara-foto.webp"
              alt="Guaciara Fornaciari"
              class="w-full h-full object-cover"
              width="512"
              height="512"
            />
          </div>
          <div class="rounded-2xl px-5 py-4 text-center w-full max-w-[288px] text-white border border-white/15 bg-white/5">
            <p class="font-bold text-base mb-1">Guaciara Fornaciari</p>
            <p class="text-xs text-white/70">Fonoaudióloga · Professora · Fundadora Doutora Escola</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Seção de ação - CTA do WhatsApp */}
  <section class={`flex-1 px-6 py-12 md:py-16 ${heroClass}`}>
    <div class="max-w-2xl mx-auto text-center">
      
      <p class="text-lg text-white/90 mb-8">
        Para receber o <strong>link da aula</strong> e todos os avisos importantes,
        entre agora no {groupName}:
      </p>

      <a
        id="sr-wa-cta"
        href={whatsappUrl}
        class={`inline-flex items-center justify-center gap-3 ${buttonClass} text-white font-black text-lg md:text-xl uppercase tracking-wide px-8 py-5 rounded-2xl ${buttonShadow} hover:scale-105 active:scale-100 transition-all duration-300 min-h-[64px] border-2 border-white/30`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-7 h-7" fill="currentColor" aria-hidden="true">
          <path d="M19.11 17.205c-.372 0-1.088 1.39-1.518 1.39a.63.63 0 0 1-.315-.1c-.802-.402-1.504-.817-2.163-1.447-.545-.516-1.146-1.29-1.46-1.963a.426.426 0 0 1-.073-.215c0-.33.99-.945.99-1.49 0-.143-.73-2.09-.832-2.335-.143-.372-.214-.487-.6-.487-.187 0-.36-.043-.53-.043-.302 0-.53.115-.746.315-.688.645-1.032 1.318-1.06 2.264v.114c-.015.99.472 1.977 1.017 2.78 1.23 1.82 2.506 3.41 4.554 4.34.616.287 2.035.888 2.722.888.817 0 2.15-.515 2.49-1.318.116-.27.244-.557.244-.86 0-.288-2.064-1.247-2.378-1.247zm-2.27 8.55c-1.79 0-3.55-.487-5.063-1.39l-3.522 1.142 1.145-3.522a9.93 9.93 0 0 1-1.605-5.422c0-5.493 4.55-9.95 10.045-9.95 5.49 0 9.946 4.457 9.946 9.95 0 5.493-4.457 9.95-9.946 9.95zm0-21.948c-6.617 0-12 5.383-12 12 0 2.118.56 4.205 1.604 6.04L4 32l5.252-1.703c1.747.92 3.708 1.405 5.693 1.405 6.617 0 12-5.383 12-12 0-3.21-1.245-6.227-3.522-8.502-2.276-2.276-5.295-3.523-8.5-3.523z"/>
        </svg>
        {isPlatinum ? 'ENTRAR NO GRUPO ABERTO PLATINUM' : 'ENTRAR NO GRUPO DO WHATSAPP'}
      </a>

      {/* Timer */}
      <div
        id="sr-wa-timer"
        class="mt-6 max-w-md mx-auto"
        data-wa-url={whatsappUrl}
      >
        <div class="h-1 w-full rounded-full bg-white/20 overflow-hidden mb-2">
          <div
            id="sr-wa-timer-bar"
            class="h-full rounded-full transition-[width] duration-1000 linear"
            style={`width: 100%; background-color: ${tierColor};`}
          >
          </div>
        </div>
        <p id="sr-wa-timer-text" class="text-sm text-white/75">
          Vou redirecionar você para o {redirectLabel} em 10 segundos…
        </p>
      </div>

      <p class="mt-8 text-white/80 text-sm md:text-base leading-relaxed max-w-lg mx-auto">
        <strong class="text-white">P.S.:</strong>
        {isPlatinum
          ? ' é pelo grupo aberto que vou organizar os avisos principais, suporte e próximos passos do Platinum. Entre agora para não perder nada.'
          : ' é pelo grupo que vou mandar o link da transmissão, os materiais e os avisos mais importantes. Não deixe de entrar.'}
      </p>
    </div>
  </section>

  {/* Seção de próximos passos - estilo consistente */}
  <section class="bg-gray-50 py-12 px-6 border-t border-gray-200">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-8">
        <p class="text-[11px] font-semibold uppercase tracking-[0.2em] mb-2" style={`color: ${tierColor};`}>
          Próximos passos
        </p>
        <h2 class="text-xl md:text-2xl font-bold text-gray-900">O que fazer agora</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        {/* Passo 1 */}
        <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-lg mx-auto mb-3" style={`background-color: ${tierColor};`}>
            1
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Entre no grupo</h3>
          <p class="text-sm text-gray-600">
            Clique no botão acima e faça parte do {isPlatinum ? 'grupo aberto Platinum' : 'grupo oficial do WhatsApp'}
          </p>
        </div>

        {/* Passo 2 */}
        <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-lg mx-auto mb-3" style={`background-color: ${tierColor};`}>
            2
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Confira seu e-mail</h3>
          <p class="text-sm text-gray-600">
            Enviamos uma confirmação. Verifique também na caixa de spam.
          </p>
        </div>

        {/* Passo 3 */}
        <div class="bg-white rounded-xl p-5 border border-gray-200 shadow-sm text-center">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-lg mx-auto mb-3" style={`background-color: ${tierColor};`}>
            3
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Salve a data</h3>
          <p class="text-sm text-gray-600">
            <strong>{SEMINARIO.dataExibida} · {SEMINARIO.horaExibida}</strong><br/>
            Não chegue atrasada!
          </p>
        </div>
      </div>
    </div>
  </section>

  <SRFooter />
</main>

<script is:inline>
  (function () {
    try {
      var nome = sessionStorage.getItem('sr_nome');
      if (!nome) {
        var params = new URLSearchParams(window.location.search);
        nome = params.get('nome');
      }
      if (nome) {
        var primeiro = String(nome).trim().split(/\s+/)[0];
        if (primeiro) {
          var el = document.getElementById('nome-aluna');
          if (el) el.textContent = ', ' + primeiro;
        }
      }
      if (window.fbq) {
        try { window.fbq('track', 'CompleteRegistration'); } catch (e) {}
      }
    } catch (e) {}

    try {
      var timerRoot = document.getElementById('sr-wa-timer');
      var bar = document.getElementById('sr-wa-timer-bar');
      var txt = document.getElementById('sr-wa-timer-text');
      var btn = document.getElementById('sr-wa-cta');
      if (!timerRoot || !bar || !txt || !btn) return;

      var link = timerRoot.getAttribute('data-wa-url') || btn.getAttribute('href') || '';
      if (!link || link === '#') return;

      function trackEntrouNoGrupo() {
        try {
          if (window.fbq) window.fbq('track', 'EntrouNoGrupo');
        } catch (e2) {}
      }

      function irParaGrupo() {
        trackEntrouNoGrupo();
        window.location.href = link;
      }

      var segundos = 10;
      var tic = setInterval(function () {
        segundos--;
        if (segundos <= 0) {
          clearInterval(tic);
          irParaGrupo();
          return;
        }
        bar.style.width = (segundos / 10) * 100 + '%';
        txt.textContent =
          'Vou redirecionar você em ' +
          segundos +
          ' segundo' +
          (segundos === 1 ? '' : 's') +
          '...';
      }, 1000);

      btn.addEventListener('click', function () {
        clearInterval(tic);
        trackEntrouNoGrupo();
      });
    } catch (e3) {}
  })();
</script>
