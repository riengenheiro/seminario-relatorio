---
import Layout from '../../layouts/Layout.astro';
import SRObrigado from '../../components/SRObrigado.astro';
import { WHATSAPP_GRUPO_VIP, SEMINARIO } from '../../config/seminario';

const title = 'Vaga VIP confirmada — ' + SEMINARIO.nome;
const description = 'Sua vaga VIP está confirmada. Entre agora no grupo oficial do WhatsApp para receber o link da aula.';
---
<Layout title={title} description={description} canonicalPath="/obrigado/vip/">
  <SRObrigado tier="VIP" whatsappUrl={WHATSAPP_GRUPO_VIP} />
</Layout>
